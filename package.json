{
  "name": "pacvideodownloader",
  "version": "1.0.0",
  "description": "PacVideoDownloader is a production-ready Ink TUI wrapper around yt-dlp.",
  "type": "module",
  "license": "MIT",
  "author": "DemirArch",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/demirgitbuh/pacvideodownloader.git"
  },
  "bin": {
    "pacv": "dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "execa": "^9.5.2",
    "ink": "^5.0.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "meow": "^13.2.0",
    "react": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
